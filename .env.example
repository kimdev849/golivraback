PORT=3000
# En hébergement production, définir explicitement : production
NODE_ENV=production

# Supabase — URL du projet (Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
# ⚠️ CLÉ SECRÈTE SERVEUR UNIQUEMENT — jamais la clé publishable !
# Supabase → Settings → API → Secret keys → sb_secret_…
# (Ou ancien JWT « service_role » — PAS « anon » ni sb_publishable_…)
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_KEY=

# Twilio SMS (OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Option A (recommandé en prod) : Messaging Service (Console Twilio → Messaging → Services)
TWILIO_MESSAGING_SERVICE_SID=
# Option B : numéro expéditeur Twilio en E.164, ex. +12025550123 (si pas de Messaging Service)
TWILIO_FROM_NUMBER=

# Origines autorisées pour le front web (séparées par des virgules). En production (NODE_ENV=production),
# si vide : les requêtes avec en-tête Origin (navigateur) sont refusées par CORS ; sans Origin (souvent mobile) OK.
# Exemple : https://golivra.vercel.app,https://xxx.exp.direct
CORS_ORIGINS=

# Limite de requêtes (optionnel). Défaut : 200 / 15 min par IP (hors GET /health), OTP : 30 / 15 min.
# RATE_LIMIT_MAX=200
# RATE_LIMIT_OTP_MAX=30

# Commerces : à la création, statut_moderation = en_attente (hors marketplace) sauf si ENTERPRISE_AUTO_APPROVE=1
# (pré-prod / démo). En production : omettre ou 0 ; l’admin active via PATCH /api/admin/enterprises/:id/activate
ENTERPRISE_AUTO_APPROVE=0

# OTP : si Twilio n'est pas configuré, le code est renvoyé dans la réponse API (mode test).
# Force le mode test même avec Twilio : OTP_TEST_MODE=1
# OTP_TEST_MODE=1

# Table OTP Supabase : auto-détection otp / otp_codes. Forcer : OTP_TABLE=otp_codes
# OTP_TABLE=otp

# Bucket Supabase Storage pour /api/uploads (créer le bucket "public" dans Supabase)
SUPABASE_STORAGE_BUCKET=public
