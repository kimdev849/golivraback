PORT=3000
# En hébergement production, définir explicitement : production
NODE_ENV=production

# Supabase — URL du projet (Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
# Clé serveur uniquement (bypass RLS). Nouveaux projets : clé secrète sb_secret_... dans le tableau des clés.
# Ancienne appellation : JWT service_role. Ne pas utiliser la clé sb_publishable_ (équivalent anon, site web / mobile).
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_KEY=

# Twilio SMS (OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Option A (recommandé en prod) : Messaging Service (Console Twilio → Messaging → Services)
TWILIO_MESSAGING_SERVICE_SID=
# Option B : numéro expéditeur Twilio en E.164, ex. +12025550123 (si pas de Messaging Service)
TWILIO_FROM_NUMBER=

# Origines autorisées pour le front web (séparées par des virgules). En production (NODE_ENV=production),
# si vide : les requêtes avec en-tête Origin (navigateur) sont refusées par CORS ; sans Origin (souvent mobile) OK.
# Exemple : https://golivra.vercel.app,https://xxx.exp.direct
CORS_ORIGINS=

# Limite de requêtes (optionnel). Défaut : 200 / 15 min par IP (hors GET /health), OTP : 30 / 15 min.
# RATE_LIMIT_MAX=200
# RATE_LIMIT_OTP_MAX=30
