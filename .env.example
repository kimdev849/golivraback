PORT=3000
# En hébergement production, définir explicitement : production
NODE_ENV=production

# Supabase — URL du projet (Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
# ⚠️ CLÉ SECRÈTE SERVEUR UNIQUEMENT — jamais la clé publishable !
# Supabase → Settings → API → Secret keys → sb_secret_…
# (Ou ancien JWT « service_role » — PAS « anon » ni sb_publishable_…)
# Préférez SUPABASE_SECRET_KEY (sb_secret_…). Si les deux sont définies, la première valide est utilisée.
SUPABASE_SECRET_KEY=
# Ancien nom (optionnel) — ne pas y mettre sb_publishable_…
SUPABASE_SERVICE_KEY=

# Twilio SMS (OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Option A (recommandé en prod) : Messaging Service (Console Twilio → Messaging → Services)
TWILIO_MESSAGING_SERVICE_SID=
# Option B : numéro expéditeur Twilio en E.164, ex. +12025550123 (si pas de Messaging Service)
TWILIO_FROM_NUMBER=

# Origines autorisées pour le front web (séparées par des virgules). En production (NODE_ENV=production),
# si vide : les requêtes avec en-tête Origin (navigateur) sont refusées par CORS ; sans Origin (souvent mobile) OK.
# Exemple : https://golivra.vercel.app,https://xxx.exp.direct
CORS_ORIGINS=

# Limite de requêtes (production uniquement — désactivé automatiquement en dev).
# Défaut production : 1000 / 15 min par IP, OTP : 50 / 15 min.
# RATE_LIMIT_MAX=1000
# RATE_LIMIT_OTP_MAX=50

# Commerces : à la création, statut_moderation = en_attente (hors marketplace) sauf si ENTERPRISE_AUTO_APPROVE=1
# (pré-prod / démo). En production : omettre ou 0 ; l’admin active via PATCH /api/admin/enterprises/:id/activate
ENTERPRISE_AUTO_APPROVE=0

# OTP : si Twilio n'est pas configuré, le code est renvoyé dans la réponse API (mode test).
# Force le mode test même avec Twilio : OTP_TEST_MODE=1
# OTP_TEST_MODE=1

# Table OTP Supabase : auto-détection otp / otp_codes. Forcer : OTP_TABLE=otp_codes
# OTP_TABLE=otp

# Bucket Supabase Storage pour /api/uploads (créer le bucket "public" dans Supabase)
SUPABASE_STORAGE_BUCKET=public

# Paiement Mobile Money : test = validation immédiate (Airtel / MTN simulés). Plus tard : airtel | mtn
PAYMENT_MODE=test

# Portefeuille plateforme GoLivra
# GOLIVRA_PLATFORM_USER_ID=
# GOLIVRA_PLATFORM_EMAIL=golivra@gmail.com

# Tarification en % (override parametres_systeme)
# MERCHANT_PERCENT=80
# PLATFORM_FEE_PERCENT=20
# DELIVERY_LOGISTICS_PERCENT=80
# DELIVERY_PLATFORM_PERCENT=20
# FRAIS_LIVRAISON_BASE_FCFA=500

# DEV : enregistre un montant aléatoire 1000–2000 en metadata (le split utilise le vrai total commande)
# PAYMENT_TEST_RANDOMIZE=1
# PAYMENT_TEST_MIN_FCFA=1000
# PAYMENT_TEST_MAX_FCFA=2000

# ── Push Notifications (Expo Push API) ─────────────────────────────────────────
# Token d'accès Expo (optionnel mais recommandé en production pour éviter le throttling).
# Obtenir sur : https://expo.dev/accounts/[username]/settings/access-tokens
# Sans ce token, les pushes fonctionnent mais sont limités à ~1000/heure par IP.
# EXPO_ACCESS_TOKEN=

# ── PawaPay (Mobile Money Congo) ─────────────────────────────────────────────
# Clé API PawaPay (header X-Api-Key). Mode sandbox pour tester.
PAWAPAY_API_KEY=
PAWAPAY_API_BASE=https://api.sandbox.pawapay.io

# Secret de signature des webhooks (HMAC-SHA256) — configurer côté dashboard PawaPay
# sur les URLs https://golivra-api.onrender.com/webhooks/pawapay/{deposits,payments,refunds}
# Si vide, la vérification de signature est désactivée (utile en dev).
# PAWAPAY_WEBHOOK_SECRET=
